# Agent-relevant fast CLI tools for agentic development flows
# Install: brew bundle --file=Brewfile

# Search & navigation
brew "ripgrep"      # grep → rg (10-50x faster)
brew "fd"           # find → fd (5-10x faster)
brew "eza"          # ls/tree → eza

# File viewing & editing
brew "bat"          # cat → bat (syntax highlighting + line ranges)
brew "sd"           # sed → sd (simpler regex, faster)

# Code intelligence
brew "tokei"        # wc -l → tokei (language-aware, JSON output)
brew "jaq"          # jq → jaq (Rust, 2-3x faster, compatible syntax)

# Dev workflow
brew "just"         # make → just (task runner)
brew "dust"         # du → dust (fast disk usage)
brew "git-delta"    # better git diff output
